generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PerfilUsuario {
  ADMIN
  ANALISTA
  CLIENTE
}

enum TipoPessoa {
  PESSOA_FISICA
  PESSOA_JURIDICA
}

enum StatusEmpresa {
  ATIVA
  INATIVA
}

enum StatusCliente {
  PROSPECT
  ATIVO
  INATIVO
}

enum StatusContrato {
  RASCUNHO
  AGUARDANDO_CONFERENCIA
  ATIVO
  SUSPENSO
  ENCERRADO
}

enum StatusProposta {
  RASCUNHO
  AGUARDANDO_ASSINATURA
  ASSINADA
  RECUSADA
  CANCELADA
  CONVERTIDA
}

enum StatusAssinatura {
  PENDENTE
  ENVIADO
  AGUARDANDO_ASSINATURA
  ASSINADO
  RECUSADO
  CANCELADO
}

enum StatusProjeto {
  PLANEJADO
  EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  CONCLUIDO
  CANCELADO
}

enum PrioridadeProjeto {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum TipoAtribuicaoTarefa {
  ANALISTA
  CLIENTE
}

enum PrioridadeTarefa {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum StatusTarefa {
  NAO_INICIADA
  EM_ANDAMENTO
  CONCLUIDA
  AGUARDANDO
  CANCELADA
  INICIADA
  AGUARDANDO_APROVACAO
}

enum TipoEntregavel {
  RELATORIO
  PLANILHA
  APRESENTACAO
  PARECER
  DIAGNOSTICO
  PLANO_DE_ACAO
  ATA
  DOCUMENTO
  OUTRO
}

enum StatusEntregavel {
  PLANEJADO
  EM_PRODUCAO
  EM_REVISAO
  AGUARDANDO_APROVACAO
  CONCLUIDO
  CANCELADO
}

enum EtapaCrm {
  LEAD_RECEBIDO
  CONTATO_INICIADO
  DIAGNOSTICO
  PROPOSTA_ENVIADA
  NEGOCIACAO
  FECHADO_GANHO
  FECHADO_PERDIDO
  POS_VENDA
}

enum StatusRecebivel {
  ABERTO
  PARCIALMENTE_RECEBIDO
  RECEBIDO
  VENCIDO
  CANCELADO
}

enum StatusFaturamento {
  PENDENTE
  EMITINDO
  EMITIDO
  CANCELADO
  ERRO
}

enum StatusContaPagar {
  ABERTO
  PAGO
  VENCIDO
  CANCELADO
}

enum TipoContaGerencial {
  RECEITA
  CUSTO
  DESPESA
  INVESTIMENTO
  TESOURARIA
}

enum TipoContaBancaria {
  CORRENTE
  POUPANCA
  CAIXA
  APLICACAO
  TRANSITORIA
  INVESTIMENTO
  OUTRA
}

enum TipoLancamentoTesouraria {
  ENTRADA
  SAIDA
  TRANSFERENCIA
  AJUSTE
}

enum TipoDocumento {
  CONTRATO
  RELATORIO_CONSULTORIA
  RELATORIO_DESLOCAMENTO
  REEMBOLSO
  TERMO_ENTREGA
  APROVACAO
  ENTREGAVEL
  OUTRO
}

enum StatusDocumento {
  RASCUNHO
  ENVIADO
  AGUARDANDO_ASSINATURA
  APROVADO
  ASSINADO
  ARQUIVADO
  CANCELADO
}

enum PrioridadeNotificacao {
  BAIXA
  MEDIA
  ALTA
}

model Empresa {
  id           String           @id @default(cuid())
  nome         String
  nomeFantasia String?
  cnpj         String?          @unique
  email        String?
  telefone     String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?
  cep          String?
  representanteNome  String?
  representanteCargo String?
  logoUrl      String?
  infBancarias String?
  status       StatusEmpresa    @default(ATIVA)
  // Configuração da empresa
  regimeTributario          String?  // SIMPLES | LUCRO_PRESUMIDO | LUCRO_REAL | MEI
  inscricaoEstadual         String?
  inscricaoMunicipal        String?
  certificadoDigitalValidade String?
  certificadoDigitalStatus  String?
  certificadoDigitalUrl     String?  // URL do .pfx no R2
  certificadoDigitalSenha   String?  // senha do certificado (criptografar no futuro)
  // Configuração fiscal NFS-e
  issAliquota               Float?   @default(5.0)
  itemListaServico          String?  // ex: "17.06" (LC 116/2003)
  codigoTributacaoMunicipio String?
  cnaeServico               String?
  enotasEmpresaId           String?  // ID da empresa no eNotas
  enotasToken               String?
  nfseAtivo                 Boolean  @default(false)
  nfseAmbiente              String   @default("homologacao")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  usuarios     Usuario[]
  clientes     Cliente[]
  contratos    Contrato[]
  propostas    Proposta[]
  contratoCobrancas ContratoCobranca[]
  projetos     Projeto[]
  tarefas      Tarefa[]
  entregaveis  Entregavel[]
  produtos     ProdutoServico[]
  recebiveis   Recebivel[]
  contasPagar  ContaPagar[]
  contasGerenciais ContaGerencial[]
  contasBancarias ContaBancaria[]
  lancamentosTesouraria LancamentoTesouraria[]
  documentos   Documento[]
  notificacoes Notificacao[]
  perfisAcesso PerfilAcesso[]
  usuarioEmpresas UsuarioEmpresa[]
  oportunidadesCrm OportunidadeCrm[]
  formulariosCaptacao FormularioCaptacao[]
  modelosDocumento ModeloDocumento[]
  deslocamentos Deslocamento[]
  funcionarios  Funcionario[]
  fornecedores  Fornecedor[]
  comentariosTarefa TarefaComentario[]
  projetoEtapas ProjetoEtapa[]
  tarefaLabels  TarefaLabel[]
  comentariosOportunidade OportunidadeCrmComentario[]
  faturamentos Faturamento[]
  checklistsDiagnostico ChecklistDiagnostico[]
  contratosModelos      ContratoModelo[]
  etapasCrm             CrmEtapa[]
}



model ProdutoServico {
  id                    String      @id @default(cuid())
  empresaId             String
  nome                  String
  descricao             String?
  contaGerencialReceita String?
  ativo                 Boolean     @default(true)
  ordem                 Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  empresa               Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contratos             Contrato[]
  propostas             Proposta[]
  projetos              Projeto[]
  recebiveis            Recebivel[]
  oportunidadesCrm      OportunidadeCrm[]
  formulariosCaptacao   FormularioCaptacao[]

  @@unique([empresaId, nome])
  @@index([empresaId])
}

model Cliente {
  id                 String       @id @default(cuid())
  empresaId          String
  tipoPessoa         TipoPessoa   @default(PESSOA_JURIDICA)
  razaoSocial        String
  nomeFantasia       String?
  cpfCnpj            String?
  inscricaoEstadual  String?
  email              String?
  telefone           String?
  whatsapp           String?
  contatoPrincipal   String?
  cep                String?
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cidade             String?
  estado             String?
  nomeFazenda        String?
  distanciaKm        Float?
  precoKmReembolso   Float?
  status             StatusCliente @default(ATIVO)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  empresa            Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contratos          Contrato[]
  propostas          Proposta[]
  usuariosAcesso     Usuario[]
  projetos           Projeto[]
  tarefasAtribuidas  Tarefa[]      @relation("TarefaResponsavelCliente")
  recebiveis         Recebivel[]
  oportunidadesCrm   OportunidadeCrm[]
  faturamentos       Faturamento[]
  deslocamentos          Deslocamento[]
  checklistsDiagnostico  ChecklistDiagnostico[]

  @@index([empresaId])
}

model Contrato {
  id                        String            @id @default(cuid())
  empresaId                 String
  clienteId                 String
  produtoServicoId          String?
  numeroContrato            String?
  codigo                    String?           @unique
  titulo                    String
  objeto                    String?
  tipoContrato              String?
  responsavelInterno        String?
  contatoClienteNome        String?
  contatoClienteEmail       String?
  contatoClienteTelefone    String?
  contatoClienteWhatsapp    String?
  clienteRazaoSocial        String?
  clienteNomeFantasia       String?
  clienteCpfCnpj            String?
  clienteInscricaoEstadual  String?
  clienteEnderecoFormatado  String?
  valor                     Float?
  moeda                     String?           @default("BRL")
  formaPagamento            String?
  periodicidadeCobranca     String?
  quantidadeParcelas        Int?
  valorParcela              Float?
  dataInicio                DateTime
  dataFim                   DateTime?
  primeiroVencimento        DateTime?
  diaVencimento             Int?
  indiceReajuste            String?
  periodicidadeReajuste     String?
  renovacaoAutomatica       Boolean           @default(false)
  status                    StatusContrato    @default(ATIVO)
  statusAssinatura          StatusAssinatura  @default(PENDENTE)
  dataEmissao               DateTime?
  dataAssinatura            DateTime?
  gerarProjetoAutomatico    Boolean           @default(false)
  gerarFinanceiroAutomatico Boolean           @default(true)
  modeloContratoNome        String?
  textoContratoBase         String?
  observacoes               String?
  autentiqueDocId           String?
  autentiqueSignUrl         String?
  pdfAssinadoUrl            String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  empresa                   Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente                   Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  produtoServico            ProdutoServico?   @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)
  projetos                  Projeto[]
  recebiveis                Recebivel[]
  documentos                Documento[]
  cobrancas                 ContratoCobranca[]
  propostasOrigem           Proposta[]
  faturamentos              Faturamento[]

  @@index([empresaId])
  @@index([clienteId])
  @@index([produtoServicoId])
}


model ContratoCobranca {
  id            String    @id @default(cuid())
  empresaId     String
  contratoId    String
  ordem         Int
  vencimento    DateTime
  valor         Float
  descricao     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  empresa       Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contrato      Contrato  @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  faturamento   Faturamento?

  @@index([empresaId])
  @@index([contratoId])
  @@unique([contratoId, ordem])
}



model ContratoModelo {
  id          String    @id @default(cuid())
  empresaId   String
  nome        String
  descricao   String?
  conteudo    String
  ativo       Boolean   @default(true)
  padrao      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
}


enum TipoModeloDocumento {
  CONTRATO
  PROPOSTA
  RELATORIO_CONSULTORIA
  RELATORIO_DESLOCAMENTO
  OUTRO
}

model ModeloDocumento {
  id          String               @id @default(cuid())
  empresaId   String
  tipo        TipoModeloDocumento  @default(CONTRATO)
  nome        String
  descricao   String?
  conteudo    String
  ativo       Boolean              @default(true)
  padrao      Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  empresa     Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, tipo, nome])
  @@index([empresaId])
  @@index([empresaId, tipo])
}

model Proposta {
  id                        String         @id @default(cuid())
  empresaId                 String
  clienteId                 String
  produtoServicoId          String?
  titulo                    String
  objeto                    String?
  responsavelInterno        String?
  contatoClienteNome        String?
  contatoClienteEmail       String?
  contatoClienteTelefone    String?
  clienteRazaoSocial        String?
  clienteCpfCnpj            String?
  clienteEnderecoFormatado  String?
  valor                     Float?
  moeda                     String?        @default("BRL")
  formaPagamento            String?
  periodicidadeCobranca     String?
  quantidadeParcelas        Int?
  valorParcela              Float?
  dataInicio                DateTime?
  dataFim                   DateTime?
  primeiroVencimento        DateTime?
  validadeAte               DateTime?
  observacoes               String?
  textoPropostaBase         String?
  status                    StatusProposta @default(RASCUNHO)
  statusAssinatura          StatusAssinatura @default(PENDENTE)
  autentiqueDocId           String?
  autentiqueSignUrl         String?
  pdfAssinadoUrl            String?
  dataAssinatura            DateTime?
  contratoGeradoId          String?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  empresa                   Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente                   Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  produtoServico            ProdutoServico? @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)
  contratoGerado            Contrato?      @relation(fields: [contratoGeradoId], references: [id], onDelete: SetNull)
  cobrancas                 PropostaCobranca[]

  @@index([empresaId])
  @@index([clienteId])
}

model PropostaCobranca {
  id          String   @id @default(cuid())
  empresaId   String
  propostaId  String
  ordem       Int
  vencimento  DateTime
  valor       Float
  descricao   String?
  createdAt   DateTime @default(now())
  proposta    Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  @@index([propostaId])
}

model Projeto {
  id                        String            @id @default(cuid())
  empresaId                 String
  clienteId                 String
  contratoId                String?
  produtoServicoId          String?
  responsavelId             String?
  gerenteId                 String?
  interno                   Boolean           @default(false)
  nome                      String
  descricao                 String?
  cor                       String            @default("#6366f1")
  equipeEnvolvida           String?
  tipoServicoProjeto        String?
  faseAtual                 String?
  percentualAndamento       Float             @default(0)
  prioridade                PrioridadeProjeto @default(MEDIA)
  recorrente                Boolean           @default(false)
  checklistInicialHabilitado Boolean          @default(false)
  modeloPadraoNome          String?
  dataInicio                DateTime
  dataFimPrevista           DateTime?
  dataInicioReal            DateTime?
  dataFimReal               DateTime?
  status                    StatusProjeto     @default(PLANEJADO)
  visivelCliente            Boolean           @default(true)
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  empresa                   Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente                   Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  contrato                  Contrato?         @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  produtoServico            ProdutoServico?   @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)
  responsavel               Usuario?          @relation("ProjetoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  gerente                   Usuario?          @relation("ProjetoGerente", fields: [gerenteId], references: [id], onDelete: SetNull)
  tarefas                   Tarefa[]
  entregaveis               Entregavel[]
  documentos                Documento[]
  deslocamentos             Deslocamento[]
  etapas                    ProjetoEtapa[]
  membros                   ProjetoMembro[]
  checklistDiagnostico      ChecklistDiagnostico?

  @@index([empresaId])
  @@index([clienteId])
  @@index([contratoId])
  @@index([produtoServicoId])
  @@index([responsavelId])
  @@index([gerenteId])
}

model Tarefa {
  id                     String             @id @default(cuid())
  empresaId              String
  projetoId              String
  etapaId                String?
  atribuicaoTipo         TipoAtribuicaoTarefa @default(ANALISTA)
  responsavelUsuarioId   String?
  responsavelClienteId   String?
  titulo                 String
  descricao              String?
  anexoUrl               String?
  comentarioResumo       String?
  checklistHabilitado    Boolean            @default(false)
  checklistJson          Json?
  subtarefasJson         Json?
  prioridade             PrioridadeTarefa   @default(MEDIA)
  prazo                  DateTime?
  estimativaHoras        Float?
  horasRegistradas       Float              @default(0)
  ordem                  Int                @default(0)
  status                 StatusTarefa       @default(NAO_INICIADA)
  aprovadorTipo          String?
  aprovadorUsuarioId     String?
  visivelCliente         Boolean            @default(false)
  concluidaEm            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  empresa                Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  projeto                Projeto            @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  etapa                  ProjetoEtapa?      @relation(fields: [etapaId], references: [id], onDelete: SetNull)
  responsavelUsuario     Usuario?           @relation("TarefaResponsavelUsuario", fields: [responsavelUsuarioId], references: [id], onDelete: SetNull)
  responsavelCliente     Cliente?           @relation("TarefaResponsavelCliente", fields: [responsavelClienteId], references: [id], onDelete: SetNull)
  aprovadorUsuario       Usuario?           @relation("TarefaAprovadorUsuario", fields: [aprovadorUsuarioId], references: [id], onDelete: SetNull)
  documentos             Documento[]
  comentarios            TarefaComentario[]
  labels                 TarefaLabelVinculo[]
  atividades             TarefaAtividade[]
  anexos                 TarefaAnexo[]

  @@index([empresaId])
  @@index([projetoId])
  @@index([etapaId])
  @@index([responsavelUsuarioId])
  @@index([responsavelClienteId])
  @@index([prazo])
}

model Entregavel {
  id                String            @id @default(cuid())
  empresaId         String
  projetoId         String
  titulo            String
  tipo              TipoEntregavel    @default(DOCUMENTO)
  descricao         String?
  dataPrevista      DateTime?
  dataConclusao     DateTime?
  status            StatusEntregavel  @default(PLANEJADO)
  visivelCliente    Boolean           @default(true)
  observacaoInterna String?
  observacaoCliente String?
  anexoUrl          String?
  comentarioResumo  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  empresa           Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  projeto           Projeto           @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  documentos        Documento[]

  @@index([empresaId])
  @@index([projetoId])
  @@index([dataPrevista])
}

model Documento {
  id                String           @id @default(cuid())
  empresaId         String
  projetoId         String?
  contratoId        String?
  tarefaId          String?
  entregavelId      String?
  nome              String
  tipo              TipoDocumento    @default(OUTRO)
  descricao         String?
  arquivoUrl        String?
  arquivoNomeOriginal String?
  arquivoMimeType   String?
  arquivoTamanho    Int?
  versao            String?
  status            StatusDocumento  @default(RASCUNHO)
  exigeAssinatura   Boolean          @default(false)
  exigeAprovacao    Boolean          @default(false)
  visivelCliente    Boolean          @default(false)
  dataEnvio         DateTime?
  dataConclusao     DateTime?
  observacaoInterna String?
  observacaoCliente String?
  autentiqueDocId   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  empresa           Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  projeto           Projeto?         @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  contrato          Contrato?        @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  tarefa            Tarefa?          @relation(fields: [tarefaId], references: [id], onDelete: SetNull)
  entregavel        Entregavel?      @relation(fields: [entregavelId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([projetoId])
  @@index([contratoId])
  @@index([tarefaId])
  @@index([entregavelId])
}

model Notificacao {
  id         String               @id @default(cuid())
  empresaId  String
  usuarioId  String
  titulo     String
  mensagem   String
  link       String?
  prioridade PrioridadeNotificacao @default(MEDIA)
  lida       Boolean              @default(false)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  empresa    Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario    Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([usuarioId])
  @@index([lida])
}

model Recebivel {
  id               String          @id @default(cuid())
  empresaId        String
  clienteId        String
  contratoId       String?
  produtoServicoId String?
  contaGerencialId String?
  descricao        String
  parcelaNumero    Int?
  totalParcelas    Int?
  grupoParcelamento String?
  valor            Float
  valorPago        Float?          @default(0)
  dataPagamento    DateTime?
  vencimento       DateTime
  dataNovoVencimento DateTime?
  previsao         Boolean         @default(false)
  status           StatusRecebivel @default(ABERTO)
  origemAutomatica Boolean         @default(false)
  faturamentoId    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  empresa          Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente          Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  contrato         Contrato?       @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  produtoServico   ProdutoServico? @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)
  contaGerencial   ContaGerencial? @relation(fields: [contaGerencialId], references: [id], onDelete: SetNull)
  faturamento      Faturamento?    @relation(fields: [faturamentoId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([clienteId])
  @@index([contratoId])
  @@index([produtoServicoId])
  @@index([contaGerencialId])
  @@index([vencimento])
  @@index([grupoParcelamento])
}



model Faturamento {
  id                    String            @id @default(cuid())
  empresaId             String
  clienteId             String
  contratoId            String?
  contratoCobrancaId    String?           @unique
  competencia           String            // "YYYY-MM"
  dataVencimento        DateTime
  valor                 Float
  descricao             String?
  observacoes           String?

  // eNotas / NFS-e
  enotasId              String?
  nfseNumero            String?
  nfseNumeroRPS         String?
  nfseSerieRPS          String?
  nfseLinkPdf           String?
  nfseLinkXml           String?
  nfseCodigoVerificacao String?
  dataEmissao           DateTime?

  status                StatusFaturamento @default(PENDENTE)
  erroEmissao           String?

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  empresa               Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente               Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
