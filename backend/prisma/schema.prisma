model ChecklistDiagnostico {
  id          String    @id @default(cuid())
  empresaId   String
  clienteId   String
  projetoId   String    @unique
  token       String    @unique @default(cuid())
  status      String    @default("PENDENTE")
  respondidoAt DateTime?

  // Bloco 3 - Estrutura Familiar
  negocioFamiliar      Boolean?
  membrosEnvolvidos    Int?
  decisaoPorConselho   Boolean?
  emSucessao           Boolean?
  geracaoSucessao      String?
  funcoesDefinidas     Boolean?
  governancaImplantada Boolean?

  // Bloco 4 - Conhecimento do Negócio
  utilizaSistemaGestao   Boolean?
  qualSistema            String?
  sabeCustoProduzir      Boolean?
  temFluxoCaixaProjetado Boolean?
  sabeCompromissoFuturo  Boolean?
  baseComercializacao    String?
  travaComercializacao   Boolean?
  negocioAlavancado      Boolean?

  // Bloco 5
  expectativaParceria String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa  Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente  Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  projeto  Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  fazendas FazendaDiagnostico[]

  @@index([empresaId])
  @@index([clienteId])
}

model FazendaDiagnostico {
  id                   String  @id @default(cuid())
  checklistId          String
  ordem                Int     @default(0)
  nomeFazenda          String
  areaTotal            Float?
  areaPlantio          Float?
  areaPlantioPropia    Float?
  areaPlantioArrendada Float?
  culturas             Json    @default("[]")
  culturaOutro         String?
  culturasAreas        Json    @default("[]")
  frustracaoSafra      Boolean @default(false)
  frustracoes          Json    @default("[]")

  checklist ChecklistDiagnostico @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}
