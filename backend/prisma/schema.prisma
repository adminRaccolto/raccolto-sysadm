  perfilAcesso    PerfilAcesso? @relation(fields: [perfilAcessoId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([usuarioId, empresaId])
  @@index([usuarioId])
  @@index([empresaId])
  @@index([perfilAcessoId])
}

model Usuario {
  id                       String        @id @default(cuid())
  empresaId                String
  clienteId                String?
  nome                     String
  email                    String        @unique
  passwordHash             String
  perfil                   PerfilUsuario
  ativo                    Boolean       @default(true)
  ultimoLoginAt            DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  empresa                  Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente                  Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  projetosResponsavel      Projeto[]     @relation("ProjetoResponsavel")
  projetosGerente          Projeto[]     @relation("ProjetoGerente")
  tarefasResponsavelUsuario Tarefa[]     @relation("TarefaResponsavelUsuario")
  tarefasAprovador         Tarefa[]      @relation("TarefaAprovadorUsuario")
  projetoMembros           ProjetoMembro[] @relation("ProjetoMembroUsuario")
  notificacoes             Notificacao[]
  empresaAcessos           UsuarioEmpresa[]
  oportunidadesResponsavel OportunidadeCrm[] @relation("OportunidadeResponsavel")
  comentariosTarefa      TarefaComentario[] @relation("ComentarioTarefaAutor")
  comentariosOportunidade OportunidadeCrmComentario[] @relation("ComentarioOportunidadeAutor")
  deslocamentos          Deslocamento[] @relation("DeslocamentoResponsavel")

  @@index([empresaId])
  @@index([clienteId])
}

model Deslocamento {
