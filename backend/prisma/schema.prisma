generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PerfilUsuario {
  ADMIN
  ANALISTA
  CLIENTE
}

enum TipoPessoa {
  PESSOA_FISICA
  PESSOA_JURIDICA
}

enum StatusEmpresa {
  ATIVA
  INATIVA
}

enum StatusCliente {
  PROSPECT
  ATIVO
  INATIVO
}

enum StatusContrato {
  RASCUNHO
  AGUARDANDO_CONFERENCIA
  ATIVO
  SUSPENSO
  ENCERRADO
}

enum StatusProposta {
  RASCUNHO
  AGUARDANDO_ASSINATURA
  ASSINADA
  RECUSADA
  CANCELADA
  CONVERTIDA
}

enum StatusAssinatura {
  PENDENTE
  ENVIADO
  AGUARDANDO_ASSINATURA
  ASSINADO
  RECUSADO
  CANCELADO
}

enum StatusProjeto {
  PLANEJADO
  EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  CONCLUIDO
  CANCELADO
}

enum PrioridadeProjeto {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum TipoAtribuicaoTarefa {
  ANALISTA
  CLIENTE
}

enum PrioridadeTarefa {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum StatusTarefa {
  NAO_INICIADA
  EM_ANDAMENTO
  CONCLUIDA
  AGUARDANDO
  CANCELADA
}

enum TipoEntregavel {
  RELATORIO
  PLANILHA
  APRESENTACAO
  PARECER
  DIAGNOSTICO
  PLANO_DE_ACAO
  ATA
  DOCUMENTO
  OUTRO
}

enum StatusEntregavel {
  PLANEJADO
  EM_PRODUCAO
  EM_REVISAO
  AGUARDANDO_APROVACAO
  CONCLUIDO
  CANCELADO
}

enum EtapaCrm {
  LEAD_RECEBIDO
  CONTATO_INICIADO
  DIAGNOSTICO
  PROPOSTA_ENVIADA
  NEGOCIACAO
  FECHADO_GANHO
  FECHADO_PERDIDO
  POS_VENDA
}

enum StatusRecebivel {
  ABERTO
  PARCIALMENTE_RECEBIDO
  RECEBIDO
  VENCIDO
  CANCELADO
}

enum StatusFaturamento {
  PENDENTE
  EMITINDO
  EMITIDO
  CANCELADO
  ERRO
}

enum StatusContaPagar {
  ABERTO
  PAGO
  VENCIDO
  CANCELADO
}

enum TipoContaGerencial {
  RECEITA
  CUSTO
  DESPESA
  INVESTIMENTO
  TESOURARIA
}

enum TipoContaBancaria {
  CORRENTE
  POUPANCA
  CAIXA
  APLICACAO
  OUTRA
}

enum TipoLancamentoTesouraria {
  ENTRADA
  SAIDA
  TRANSFERENCIA
  AJUSTE
}

enum TipoDocumento {
  CONTRATO
  RELATORIO_CONSULTORIA
  RELATORIO_DESLOCAMENTO
  REEMBOLSO
  TERMO_ENTREGA
  APROVACAO
  ENTREGAVEL
  OUTRO
}

enum StatusDocumento {
  RASCUNHO
  ENVIADO
  AGUARDANDO_ASSINATURA
  APROVADO
  ASSINADO
  ARQUIVADO
  CANCELADO
}

enum PrioridadeNotificacao {
  BAIXA
  MEDIA
  ALTA
}

model Empresa {
  id           String           @id @default(cuid())
  nome         String
  nomeFantasia String?
  cnpj         String?          @unique
  email        String?
  telefone     String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?
  cep          String?
  representanteNome  String?
  representanteCargo String?
  logoUrl      String?
  status       StatusEmpresa    @default(ATIVA)
  // Configuração fiscal para NFS-e
  issAliquota               Float?   @default(5.0)
  itemListaServico          String?  // ex: "17.06" (LC 116/2003)
  codigoTributacaoMunicipio String?
  cnaeServico               String?
  enotasEmpresaId           String?  // ID da empresa no eNotas
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  usuarios     Usuario[]
  clientes     Cliente[]
  contratos    Contrato[]
  propostas    Proposta[]
  contratoCobrancas ContratoCobranca[]
  projetos     Projeto[]
  tarefas      Tarefa[]
  entregaveis  Entregavel[]
  produtos     ProdutoServico[]
  recebiveis   Recebivel[]
  contasPagar  ContaPagar[]
  contasGerenciais ContaGerencial[]
  contasBancarias ContaBancaria[]
  lancamentosTesouraria LancamentoTesouraria[]
  documentos   Documento[]
  notificacoes Notificacao[]
  perfisAcesso PerfilAcesso[]
  usuarioEmpresas UsuarioEmpresa[]
  oportunidadesCrm OportunidadeCrm[]
  formulariosCaptacao FormularioCaptacao[]
  modelosDocumento ModeloDocumento[]
  deslocamentos Deslocamento[]
  comentariosTarefa TarefaComentario[]
  comentariosOportunidade OportunidadeCrmComentario[]
  faturamentos Faturamento[]
}



model ProdutoServico {
  id                    String      @id @default(cuid())
  empresaId             String
  nome                  String
  descricao             String?
  contaGerencialReceita String?
  ativo                 Boolean     @default(true)
  ordem                 Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  empresa               Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contratos             Contrato[]
  propostas             Proposta[]
  projetos              Projeto[]
  recebiveis            Recebivel[]
  oportunidadesCrm      OportunidadeCrm[]
  formulariosCaptacao   FormularioCaptacao[]

  @@unique([empresaId, nome])
  @@index([empresaId])
}

model Cliente {
  id                 String       @id @default(cuid())
  empresaId          String
  tipoPessoa         TipoPessoa   @default(PESSOA_JURIDICA)
  razaoSocial        String
  nomeFantasia       String?
  cpfCnpj            String?
  inscricaoEstadual  String?
  email              String?
  telefone           String?
  whatsapp           String?
  contatoPrincipal   String?
  cep                String?
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cidade             String?
  estado             String?
  nomeFazenda        String?
  distanciaKm        Float?
  precoKmReembolso   Float?
  status             StatusCliente @default(ATIVO)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  empresa            Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contratos          Contrato[]
  propostas          Proposta[]
  usuariosAcesso     Usuario[]
  projetos           Projeto[]
  tarefasAtribuidas  Tarefa[]      @relation("TarefaResponsavelCliente")
  recebiveis         Recebivel[]
  oportunidadesCrm   OportunidadeCrm[]
  faturamentos       Faturamento[]
  deslocamentos      Deslocamento[]

  @@index([empresaId])
}

model Contrato {
  id                        String            @id @default(cuid())
  empresaId                 String
  clienteId                 String
  produtoServicoId          String?
  numeroContrato            String?
  codigo                    String?           @unique
  titulo                    String
  objeto                    String?
  tipoContrato              String?
  responsavelInterno        String?
  contatoClienteNome        String?
  contatoClienteEmail       String?
  contatoClienteTelefone    String?
  contatoClienteWhatsapp    String?
  clienteRazaoSocial        String?
  clienteNomeFantasia       String?
  clienteCpfCnpj            String?
  clienteInscricaoEstadual  String?
  clienteEnderecoFormatado  String?
  valor                     Float?
  moeda                     String?           @default("BRL")
  formaPagamento            String?
  periodicidadeCobranca     String?
  quantidadeParcelas        Int?
  valorParcela              Float?
  dataInicio                DateTime
  dataFim                   DateTime?
  primeiroVencimento        DateTime?
  diaVencimento             Int?
  indiceReajuste            String?
  periodicidadeReajuste     String?
  renovacaoAutomatica       Boolean           @default(false)
  status                    StatusContrato    @default(ATIVO)
  statusAssinatura          StatusAssinatura  @default(PENDENTE)
  dataEmissao               DateTime?
  dataAssinatura            DateTime?
  gerarProjetoAutomatico    Boolean           @default(false)
  gerarFinanceiroAutomatico Boolean           @default(true)
  modeloContratoNome        String?
  textoContratoBase         String?
  observacoes               String?
  autentiqueDocId           String?
  autentiqueSignUrl         String?
  pdfAssinadoUrl            String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  empresa                   Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente                   Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  produtoServico            ProdutoServico?   @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)
  projetos                  Projeto[]
  recebiveis                Recebivel[]
  documentos                Documento[]
  cobrancas                 ContratoCobranca[]
  propostasOrigem           Proposta[]
  faturamentos              Faturamento[]

  @@index([empresaId])
  @@index([clienteId])
  @@index([produtoServicoId])
}


model ContratoCobranca {
  id            String    @id @default(cuid())
  empresaId     String
  contratoId    String
  ordem         Int
  vencimento    DateTime
  valor         Float
  descricao     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  empresa       Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contrato      Contrato  @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  faturamento   Faturamento?

  @@index([empresaId])
  @@index([contratoId])
  @@unique([contratoId, ordem])
}



enum TipoModeloDocumento {
  CONTRATO
  PROPOSTA
  RELATORIO_CONSULTORIA
  RELATORIO_DESLOCAMENTO
  OUTRO
}

model ModeloDocumento {
  id          String               @id @default(cuid())
  empresaId   String
  tipo        TipoModeloDocumento  @default(CONTRATO)
  nome        String
  descricao   String?
  conteudo    String
  ativo       Boolean              @default(true)
  padrao      Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  empresa     Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, tipo, nome])
  @@index([empresaId])
  @@index([empresaId, tipo])
}

model Proposta {
  id                        String         @id @default(cuid())
  empresaId                 String
  clienteId                 String
  produtoServicoId          String?
  titulo                    String
  objeto                    String?
  responsavelInterno        String?
  contatoClienteNome        String?
  contatoClienteEmail       String?
  contatoClienteTelefone    String?
  clienteRazaoSocial        String?
  clienteCpfCnpj            String?
  clienteEnderecoFormatado  String?
  valor                     Float?
  moeda                     String?        @default("BRL")
  formaPagamento            String?
  periodicidadeCobranca     String?
  quantidadeParcelas        Int?
  valorParcela              Float?
  dataInicio                DateTime?
  dataFim                   DateTime?
  primeiroVencimento        DateTime?
  validadeAte               DateTime?
  observacoes               String?
  textoPropostaBase         String?
  status                    StatusProposta @default(RASCUNHO)
  statusAssinatura          StatusAssinatura @default(PENDENTE)
  autentiqueDocId           String?
  autentiqueSignUrl         String?
  pdfAssinadoUrl            String?
  dataAssinatura            DateTime?
  contratoGeradoId          String?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  empresa                   Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente                   Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  produtoServico            ProdutoServico? @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)
  contratoGerado            Contrato?      @relation(fields: [contratoGeradoId], references: [id], onDelete: SetNull)
  cobrancas                 PropostaCobranca[]

  @@index([empresaId])
  @@index([clienteId])
}

model PropostaCobranca {
  id          String   @id @default(cuid())
  empresaId   String
  propostaId  String
  ordem       Int
  vencimento  DateTime
  valor       Float
  descricao   String?
  createdAt   DateTime @default(now())
  proposta    Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  @@index([propostaId])
}

model Projeto {
  id                        String            @id @default(cuid())
  empresaId                 String
  clienteId                 String
  contratoId                String?
  produtoServicoId          String?
  responsavelId             String?
  interno                   Boolean           @default(false)
  nome                      String
  descricao                 String?
  equipeEnvolvida           String?
  tipoServicoProjeto        String?
  faseAtual                 String?
  percentualAndamento       Float             @default(0)
  prioridade                PrioridadeProjeto @default(MEDIA)
  recorrente                Boolean           @default(false)
  checklistInicialHabilitado Boolean          @default(false)
  modeloPadraoNome          String?
  dataInicio                DateTime
  dataFimPrevista           DateTime?
  dataInicioReal            DateTime?
  dataFimReal               DateTime?
  status                    StatusProjeto     @default(PLANEJADO)
  visivelCliente            Boolean           @default(true)
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  empresa                   Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente                   Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  contrato                  Contrato?         @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  produtoServico            ProdutoServico?   @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)
  responsavel               Usuario?          @relation("ProjetoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  tarefas                   Tarefa[]
  entregaveis               Entregavel[]
  documentos                Documento[]
  deslocamentos             Deslocamento[]

  @@index([empresaId])
  @@index([clienteId])
  @@index([contratoId])
  @@index([produtoServicoId])
  @@index([responsavelId])
}

model Tarefa {
  id                     String             @id @default(cuid())
  empresaId              String
  projetoId              String
  atribuicaoTipo         TipoAtribuicaoTarefa @default(ANALISTA)
  responsavelUsuarioId   String?
  responsavelClienteId   String?
  titulo                 String
  descricao              String?
  anexoUrl               String?
  comentarioResumo       String?
  checklistHabilitado    Boolean            @default(false)
  checklistJson          Json?
  subtarefasJson         Json?
  prioridade             PrioridadeTarefa   @default(MEDIA)
  prazo                  DateTime?
  status                 StatusTarefa       @default(NAO_INICIADA)
  visivelCliente         Boolean            @default(false)
  concluidaEm            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  empresa                Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  projeto                Projeto            @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  responsavelUsuario     Usuario?           @relation("TarefaResponsavelUsuario", fields: [responsavelUsuarioId], references: [id], onDelete: SetNull)
  responsavelCliente     Cliente?           @relation("TarefaResponsavelCliente", fields: [responsavelClienteId], references: [id], onDelete: SetNull)
  documentos             Documento[]
  comentarios            TarefaComentario[]

  @@index([empresaId])
  @@index([projetoId])
  @@index([responsavelUsuarioId])
  @@index([responsavelClienteId])
  @@index([prazo])
}

model Entregavel {
  id                String            @id @default(cuid())
  empresaId         String
  projetoId         String
  titulo            String
  tipo              TipoEntregavel    @default(DOCUMENTO)
  descricao         String?
  dataPrevista      DateTime?
  dataConclusao     DateTime?
  status            StatusEntregavel  @default(PLANEJADO)
  visivelCliente    Boolean           @default(true)
  observacaoInterna String?
  observacaoCliente String?
  anexoUrl          String?
  comentarioResumo  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  empresa           Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  projeto           Projeto           @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  documentos        Documento[]

  @@index([empresaId])
  @@index([projetoId])
  @@index([dataPrevista])
}

model Documento {
  id                String           @id @default(cuid())
  empresaId         String
  projetoId         String?
  contratoId        String?
  tarefaId          String?
  entregavelId      String?
  nome              String
  tipo              TipoDocumento    @default(OUTRO)
  descricao         String?
  arquivoUrl        String?
  arquivoNomeOriginal String?
  arquivoMimeType   String?
  arquivoTamanho    Int?
  versao            String?
  status            StatusDocumento  @default(RASCUNHO)
  exigeAssinatura   Boolean          @default(false)
  exigeAprovacao    Boolean          @default(false)
  visivelCliente    Boolean          @default(false)
  dataEnvio         DateTime?
  dataConclusao     DateTime?
  observacaoInterna String?
  observacaoCliente String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  empresa           Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  projeto           Projeto?         @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  contrato          Contrato?        @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  tarefa            Tarefa?          @relation(fields: [tarefaId], references: [id], onDelete: SetNull)
  entregavel        Entregavel?      @relation(fields: [entregavelId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([projetoId])
  @@index([contratoId])
  @@index([tarefaId])
  @@index([entregavelId])
}

model Notificacao {
  id         String               @id @default(cuid())
  empresaId  String
  usuarioId  String
  titulo     String
  mensagem   String
  link       String?
  prioridade PrioridadeNotificacao @default(MEDIA)
  lida       Boolean              @default(false)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  empresa    Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario    Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([usuarioId])
  @@index([lida])
}

model Recebivel {
  id               String          @id @default(cuid())
  empresaId        String
  clienteId        String
  contratoId       String?
  produtoServicoId String?
  contaGerencialId String?
  descricao        String
  parcelaNumero    Int?
  totalParcelas    Int?
  grupoParcelamento String?
  valor            Float
  valorPago        Float?          @default(0)
  dataPagamento    DateTime?
  vencimento       DateTime
  dataNovoVencimento DateTime?
  previsao         Boolean         @default(false)
  status           StatusRecebivel @default(ABERTO)
  origemAutomatica Boolean         @default(false)
  faturamentoId    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  empresa          Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente          Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  contrato         Contrato?       @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  produtoServico   ProdutoServico? @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)
  contaGerencial   ContaGerencial? @relation(fields: [contaGerencialId], references: [id], onDelete: SetNull)
  faturamento      Faturamento?    @relation(fields: [faturamentoId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([clienteId])
  @@index([contratoId])
  @@index([produtoServicoId])
  @@index([contaGerencialId])
  @@index([vencimento])
  @@index([grupoParcelamento])
}



model Faturamento {
  id                    String            @id @default(cuid())
  empresaId             String
  clienteId             String
  contratoId            String?
  contratoCobrancaId    String?           @unique
  competencia           String            // "YYYY-MM"
  dataVencimento        DateTime
  valor                 Float
  descricao             String?
  observacoes           String?

  // eNotas / NFS-e
  enotasId              String?
  nfseNumero            String?
  nfseNumeroRPS         String?
  nfseSerieRPS          String?
  nfseLinkPdf           String?
  nfseLinkXml           String?
  nfseCodigoVerificacao String?
  dataEmissao           DateTime?

  status                StatusFaturamento @default(PENDENTE)
  erroEmissao           String?

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  empresa               Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente               Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  contrato              Contrato?         @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  contratoCobranca      ContratoCobranca? @relation(fields: [contratoCobrancaId], references: [id], onDelete: SetNull)
  recebiveis            Recebivel[]

  @@index([empresaId])
  @@index([clienteId])
  @@index([contratoId])
  @@index([competencia])
}


model OportunidadeCrm {
  id                String    @id @default(cuid())
  empresaId         String
  clienteId         String?
  produtoServicoId  String?
  responsavelId     String?
  titulo            String
  empresaNome       String
  contatoNome       String?
  email             String?
  telefone          String?
  whatsapp          String?
  origemLead        String?
  valorEstimado     Float?
  etapa             EtapaCrm  @default(LEAD_RECEBIDO)
  probabilidade     Int       @default(10)
  previsaoFechamento DateTime?
  proximaAcao       String?
  dataProximaAcao   DateTime?
  motivoPerda       String?
  observacoes       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  empresa           Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente           Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  produtoServico    ProdutoServico? @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)
  responsavel       Usuario?  @relation("OportunidadeResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  comentarios       OportunidadeCrmComentario[]
  submissoesFormulario FormularioSubmissao[]

  @@index([empresaId])
  @@index([clienteId])
  @@index([produtoServicoId])
  @@index([responsavelId])
  @@index([etapa])
}

model TarefaComentario {
  id            String    @id @default(cuid())
  empresaId      String
  tarefaId       String
  autorUsuarioId String?
  autorNome      String
  mensagem       String
  createdAt      DateTime  @default(now())
  empresa        Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  tarefa         Tarefa    @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  autorUsuario   Usuario?  @relation("ComentarioTarefaAutor", fields: [autorUsuarioId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([tarefaId])
  @@index([autorUsuarioId])
}

model OportunidadeCrmComentario {
  id              String          @id @default(cuid())
  empresaId        String
  oportunidadeId   String
  autorUsuarioId   String?
  autorNome        String
  mensagem         String
  createdAt        DateTime        @default(now())
  empresa          Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  oportunidade     OportunidadeCrm @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)
  autorUsuario     Usuario?        @relation("ComentarioOportunidadeAutor", fields: [autorUsuarioId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([oportunidadeId])
  @@index([autorUsuarioId])
}

model ContaGerencial {
  id               String            @id @default(cuid())
  empresaId        String
  contaPaiId       String?
  codigo           String
  descricao        String
  tipo             TipoContaGerencial
  aceitaLancamento Boolean           @default(true)
  ativo            Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  empresa          Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contaPai         ContaGerencial?   @relation("HierarquiaContaGerencial", fields: [contaPaiId], references: [id], onDelete: SetNull)
  subcontas        ContaGerencial[]  @relation("HierarquiaContaGerencial")
  recebiveis       Recebivel[]
  contasPagar      ContaPagar[]
  lancamentos      LancamentoTesouraria[]

  @@unique([empresaId, codigo])
  @@index([empresaId])
  @@index([contaPaiId])
}

model ContaBancaria {
  id            String            @id @default(cuid())
  empresaId      String
  nome           String
  banco          String?
  agencia        String?
  numeroConta    String?
  tipo           TipoContaBancaria @default(CORRENTE)
  saldoInicial   Float             @default(0)
  saldoAtual     Float             @default(0)
  ativo          Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  empresa        Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  lancamentos    LancamentoTesouraria[]

  @@index([empresaId])
}

model ContaPagar {
  id                String           @id @default(cuid())
  empresaId         String
  contaGerencialId  String
  fornecedor        String?
  descricao         String
  competencia       DateTime
  dataCompra        DateTime?
  vencimento        DateTime
  valor             Float
  valorTotalCompra  Float?
  parcelado         Boolean          @default(false)
  grupoParcelamento String?
  parcelaNumero     Int?
  totalParcelas     Int?
  recorrente        Boolean          @default(false)
  anexoUrl          String?
  previsao          Boolean          @default(false)
  status            StatusContaPagar @default(ABERTO)
  observacoes       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  empresa           Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contaGerencial    ContaGerencial   @relation(fields: [contaGerencialId], references: [id], onDelete: Restrict)

  @@index([empresaId])
  @@index([contaGerencialId])
  @@index([competencia])
  @@index([vencimento])
  @@index([grupoParcelamento])
}

model LancamentoTesouraria {
  id               String                   @id @default(cuid())
  empresaId        String
  contaBancariaId  String
  contaGerencialId String
  tipo             TipoLancamentoTesouraria
  descricao        String
  dataLancamento   DateTime
  valor            Float
  observacoes      String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  empresa          Empresa                  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contaBancaria    ContaBancaria            @relation(fields: [contaBancariaId], references: [id], onDelete: Restrict)
  contaGerencial   ContaGerencial           @relation(fields: [contaGerencialId], references: [id], onDelete: Restrict)

  @@index([empresaId])
  @@index([contaBancariaId])
  @@index([contaGerencialId])
  @@index([dataLancamento])
}


model RecursoSistema {
  id          String              @id @default(cuid())
  chave       String              @unique
  nome        String
  descricao   String?
  ordem       Int                 @default(0)
  ativo       Boolean             @default(true)
  permissoes  PerfilPermissao[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model PerfilAcesso {
  id             String             @id @default(cuid())
  empresaId       String
  nome            String
  descricao       String?
  ativo           Boolean            @default(true)
  padraoSistema   Boolean            @default(false)
  empresa         Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  permissoes      PerfilPermissao[]
  usuariosEmpresa UsuarioEmpresa[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([empresaId, nome])
  @@index([empresaId])
}

model PerfilPermissao {
  id               String          @id @default(cuid())
  perfilAcessoId   String
  recursoSistemaId String
  visualizar       Boolean         @default(true)
  criar            Boolean         @default(false)
  editar           Boolean         @default(false)
  excluir          Boolean         @default(false)
  aprovar          Boolean         @default(false)
  administrar      Boolean         @default(false)
  perfilAcesso     PerfilAcesso    @relation(fields: [perfilAcessoId], references: [id], onDelete: Cascade)
  recursoSistema   RecursoSistema  @relation(fields: [recursoSistemaId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([perfilAcessoId, recursoSistemaId])
  @@index([perfilAcessoId])
  @@index([recursoSistemaId])
}

model UsuarioEmpresa {
  id             String        @id @default(cuid())
  usuarioId       String
  empresaId       String
  perfilAcessoId  String?
  principal       Boolean       @default(false)
  ativo           Boolean       @default(true)
  usuario         Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresa         Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  perfilAcesso    PerfilAcesso? @relation(fields: [perfilAcessoId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([usuarioId, empresaId])
  @@index([usuarioId])
  @@index([empresaId])
  @@index([perfilAcessoId])
}

model Usuario {
  id                       String        @id @default(cuid())
  empresaId                String
  clienteId                String?
  nome                     String
  email                    String        @unique
  passwordHash             String
  perfil                   PerfilUsuario
  ativo                    Boolean       @default(true)
  ultimoLoginAt            DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  empresa                  Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente                  Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  projetosResponsavel      Projeto[]     @relation("ProjetoResponsavel")
  tarefasResponsavelUsuario Tarefa[]     @relation("TarefaResponsavelUsuario")
  notificacoes             Notificacao[]
  empresaAcessos           UsuarioEmpresa[]
  oportunidadesResponsavel OportunidadeCrm[] @relation("OportunidadeResponsavel")
  comentariosTarefa      TarefaComentario[] @relation("ComentarioTarefaAutor")
  comentariosOportunidade OportunidadeCrmComentario[] @relation("ComentarioOportunidadeAutor")
  deslocamentos          Deslocamento[] @relation("DeslocamentoResponsavel")

  @@index([empresaId])
  @@index([clienteId])
}

model Deslocamento {
  id             String   @id @default(cuid())
  empresaId      String
  projetoId      String
  clienteId      String
  responsavelId  String?
  data           DateTime
  distanciaKm    Float
  precoKm        Float
  valorTotal     Float
  descricao      String?
  observacoes    String?
  reembolsado    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  empresa        Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  projeto        Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  cliente        Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  responsavel    Usuario? @relation("DeslocamentoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([projetoId])
  @@index([clienteId])
}

model FormularioCaptacao {
  id               String               @id @default(cuid())
  empresaId        String
  produtoServicoId String?
  nome             String
  slug             String
  origemLead       String               // WHATSAPP | EMAIL | INSTAGRAM | OUTRO
  etapaInicial     EtapaCrm             @default(LEAD_RECEBIDO)
  titulo           String
  descricao        String?
  ativo            Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  empresa          Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produtoServico   ProdutoServico?      @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)
  submissoes       FormularioSubmissao[]

  @@unique([empresaId, slug])
  @@index([empresaId])
  @@index([produtoServicoId])
}

model FormularioSubmissao {
  id             String              @id @default(cuid())
  formularioId   String
  oportunidadeId String?
  nomeContato    String
  empresaNome    String?
  email          String?
  telefone       String?
  mensagem       String?
  createdAt      DateTime            @default(now())
  formulario     FormularioCaptacao  @relation(fields: [formularioId], references: [id], onDelete: Cascade)
  oportunidade   OportunidadeCrm?   @relation(fields: [oportunidadeId], references: [id], onDelete: SetNull)

  @@index([formularioId])
  @@index([oportunidadeId])
}
