model Funcionario {
  id                    String      @id @default(cuid())
  empresaId             String
  nome                  String
  documento             String?     // CPF ou RG (número)
  tipoDocumento         String?     // "CPF" | "RG"
  cpf                   String?     // mantido por compatibilidade
  email                 String?
  telefone              String?
  sexo                  String?     // "M" | "F" | "OUTRO"
  fotoUrl               String?
  cargo                 String?
  vinculo               String      @default("CLT") // CLT | PJ | FREELANCER | ESTAGIO
  salario               Float?
  dataAdmissao          DateTime?
  dataDemissao          DateTime?
  dataNascimento        DateTime?
  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  cidade                String?
  estado                String?
  cep                   String?
  contaBancariaNome     String?
  contaBancariaAgencia  String?
  contaBancariaConta    String?
  contaBancariaBanco    String?
  contaBancariaPix      String?
  usuarioId             String?     // se terá acesso ao sistema
  fornecedorId          String?     // se PJ, vínculo com fornecedor
  ativo                 Boolean     @default(true)
  observacoes           String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  empresa               Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fornecedor            Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)

