  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String?
  estado          String?
  cep             String?
  nomeContato     String?
  telefoneEmpresa String?
  telefoneContato String?
  whatsapp        String?
  email           String?
  observacoes     String?
  ativo           Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  empresa         Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  funcionarios    Funcionario[]

  @@index([empresaId])
}

model ContaPagar {
  id                String           @id @default(cuid())
  empresaId         String
  contaGerencialId  String
  fornecedor        String?
  descricao         String
  competencia       DateTime
  dataCompra        DateTime?
  vencimento        DateTime
  valor             Float
  valorTotalCompra  Float?
  parcelado         Boolean          @default(false)
  grupoParcelamento String?
  parcelaNumero     Int?
  totalParcelas     Int?
  recorrente        Boolean          @default(false)
  anexoUrl          String?
  previsao          Boolean          @default(false)
  status            StatusContaPagar @default(ABERTO)
  observacoes       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  empresa           Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contaGerencial    ContaGerencial   @relation(fields: [contaGerencialId], references: [id], onDelete: Restrict)

  @@index([empresaId])
  @@index([contaGerencialId])
  @@index([competencia])
  @@index([vencimento])
  @@index([grupoParcelamento])
}

model LancamentoTesouraria {
